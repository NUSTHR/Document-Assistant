APP_NAME=ragflow-integration-service
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8081
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

RAGFLOW_BASE_URL=http://127.0.0.1:18080
RAGFLOW_API_KEY=ragflow-REPLACE-WITH-YOUR-ACTUAL-KEY
RAGFLOW_IDENTITY_SECRET=documentation-assistant-local-identity
RAGFLOW_ALLOW_SERVICE_API_KEY_FALLBACK=false
RAGFLOW_TIMEOUT_SECONDS=60
DEFAULT_CHAT_AGENT_CONFIG_PATH=
